title: شكراً لك
---

<style>
  .merci-page { min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 20px; }
  .merci-content { max-width: 500px; }
  .success-icon { width: 100px; height: 100px; background: linear-gradient(135deg, #16a34a, #22c55e); border-radius: 50%; margin: 0 auto 30px; display: flex; align-items: center; justify-content: center; font-size: 3rem; }
  .merci-content h1 { font-size: 2rem; font-weight: 900; margin-bottom: 16px; color: var(--text); }
  .merci-content p { font-size: 1.1rem; color: var(--text-mid); margin-bottom: 30px; line-height: 1.8; }
</style>

<section class="merci-page">
  <div class="merci-content">
    <div class="success-icon">✓</div>
    <h1>شكراً لك! ✨</h1>
    <p>تم استلام طلبك بنجاح. سنتصل بك قريباً لتأكيد الطلب.</p>
    <a href="/" class="btn btn-primary btn-lg">العودة للرئيسية</a>
  </div>
</section>

<script>
  (function () {
    const src = new URLSearchParams(window.location.search).get('src');
    if (src !== 'order-single' && src !== 'order-cart') return;
    if (!window.fbq) return;

    const dedupeKey = 'bouda_purchase_sent_v1';
    try {
      if (sessionStorage.getItem(dedupeKey) === '1') return;
      sessionStorage.setItem(dedupeKey, '1');
    } catch (_) {
      // Ignore storage access errors and continue.
    }

    let amount = 0;
    try {
      const raw = localStorage.getItem('bouda_pending_purchase_v1');
      if (raw) {
        const payload = JSON.parse(raw);
        if (payload && payload.source === src) {
          amount = Number(payload.total) || 0;
        }
      }
      localStorage.removeItem('bouda_pending_purchase_v1');
    } catch (_) {
      // Ignore JSON/storage errors and use fallback amount.
    }

    if (amount > 0) {
      fbq('track', 'Purchase', { value: amount, currency: 'DZD' });
    } else {
      fbq('track', 'Purchase', { currency: 'DZD' });
    }
  })();
</script>
