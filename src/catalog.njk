---
layout: base.njk
title: المنتجات
---

<style>
  .catalog-header { background: linear-gradient(180deg, #eef4ff 0%, var(--bg) 100%); padding: 40px 20px; text-align: center; }
  .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
  .filter-buttons { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 30px; }
  .filter-btn { padding: 10px 20px; border: 2px solid var(--border); background: var(--surface); border-radius: 25px; font-family: 'Cairo', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; }
  .filter-btn:hover, .filter-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
</style>

<section class="catalog-header">
  <div class="container">
    <h1 class="section-title" data-i18n="catalog.title">📚 جميع المنتجات</h1>
    <p class="section-subtitle" data-i18n="catalog.sub">اختر الكتاب المناسب لمستواك الدراسي</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="filter-buttons">
      <button class="filter-btn active" data-filter="all" data-i18n="catalog.filter.all">الكل</button>
      {% for category in collections.categories %}
      <button class="filter-btn" data-filter="{{ category.data.slug }}">{{ category.data.name }}</button>
      {% endfor %}
    </div>

    <div class="products-grid" id="productsGrid">
      {% for product in collections.products %}
      <div class="product-card" data-category="{{ product.data.category }}">
        <div class="product-card-img">
          {% if product.data.badge %}<span class="product-badge">{{ product.data.badge }}</span>{% endif %}
          <img src="{{ product.data.image }}" alt="{{ product.data.name }}">
        </div>
        <div class="product-card-body">
          <h3 class="product-card-title">{{ product.data.name }}</h3>
          <p class="product-card-desc">{{ product.data.description }}</p>
        </div>
        <div class="product-card-footer">
          <div>
            <div class="product-price">{{ product.data.price }} <small>دج</small></div>
            {% if product.data.oldPrice %}<div class="product-price-old">{{ product.data.oldPrice }} دج</div>{% endif %}
          </div>
          <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end;">
            <a href="/product/{{ product.data.slug or product.fileSlug }}/" class="btn btn-primary" style="padding: 10px 14px; font-size: 0.85rem;">
              <span data-i18n="common.details">التفاصيل</span>
            </a>
            <button
              type="button"
              class="btn btn-secondary add-to-cart-btn"
              style="padding: 10px 14px; font-size: 0.85rem;"
              data-id="{{ product.data.slug or product.fileSlug }}"
              data-slug="{{ product.data.slug or product.fileSlug }}"
              data-name="{{ product.data.name }}"
              data-price="{{ product.data.price }}"
              data-image="{{ product.data.image }}"
            >
              <span data-i18n="common.addCart">+ السلة</span>
            </button>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll('.product-card').forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? 'flex' : 'none';
      });
    });
  });

  document.querySelectorAll('.add-to-cart-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!window.BoudaCart) return;
      window.BoudaCart.addItem({
        id: btn.dataset.id,
        slug: btn.dataset.slug,
        name: btn.dataset.name,
        price: Number(btn.dataset.price),
        image: btn.dataset.image,
        qty: 1
      });
      const lang = window.BoudaI18n ? window.BoudaI18n.getLang() : 'ar';
      btn.textContent = lang === 'fr' ? '✓ Ajouté' : '✓ تمت الإضافة';
      setTimeout(() => {
        btn.textContent = lang === 'fr' ? '+ Panier' : '+ السلة';
      }, 1200);
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    if (!window.BoudaI18n) return;
    const lang = window.BoudaI18n.getLang();
    if (lang === 'fr') {
      document.querySelectorAll('.add-to-cart-btn').forEach((btn) => { btn.textContent = '+ Panier'; });
    }
  });
</script>
