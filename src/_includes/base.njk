  <script>
    (function () {
      const CART_KEY = "bouda_cart_v1";

      function getCart() {
        try {
          const raw = localStorage.getItem(CART_KEY);
          return raw ? JSON.parse(raw) : [];
        } catch (_) {
          return [];
        }
      }

      function saveCart(items) {
        localStorage.setItem(CART_KEY, JSON.stringify(items));
        updateBadge();
      }

      function updateBadge() {
        const count = getCart().reduce((sum, item) => sum + (item.qty || 0), 0);
        const desktop = document.getElementById("cartCount");
        const mobile = document.getElementById("cartCountMobile");
        if (desktop) desktop.textContent = String(count);
        if (mobile) mobile.textContent = String(count);
      }

      function addItem(item) {
        const items = getCart();
        const id = item.id || item.slug || item.name;
        const existing = items.find((it) => it.id === id);
        if (existing) {
          existing.qty += item.qty || 1;
        } else {
          items.push({
            id,
            name: item.name,
            slug: item.slug,
            price: Number(item.price) || 0,
            image: item.image || "/book.jpg",
            qty: item.qty || 1
          });
        }
        saveCart(items);
      }

      function removeItem(id) {
        saveCart(getCart().filter((item) => item.id !== id));
      }

      function updateQty(id, qty) {
        const items = getCart();
        const item = items.find((it) => it.id === id);
        if (!item) return;
        item.qty = Math.max(1, Number(qty) || 1);
        saveCart(items);
      }

      window.BoudaCart = { getCart, saveCart, addItem, removeItem, updateQty, updateBadge };
      document.addEventListener("DOMContentLoaded", updateBadge);
    })();

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
