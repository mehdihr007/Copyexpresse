          "cart.confirm": "🛒 Confirmer la commande"
        }
      };

      function getLang() {
        return localStorage.getItem(LANG_KEY) || "ar";
      }

      function t(key, lang) {
        const selected = lang || getLang();
        return (I18N[selected] && I18N[selected][key]) || key;
      }

      function applyLanguage(lang) {
        document.documentElement.lang = lang === "fr" ? "fr" : "ar";
        document.documentElement.dir = lang === "fr" ? "ltr" : "rtl";
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");
          const value = t(key, lang);
          if (value) el.textContent = value;
        });
        document.querySelectorAll("[data-i18n-html]").forEach((el) => {
          const key = el.getAttribute("data-i18n-html");
          const value = t(key, lang);
          if (value) el.innerHTML = value;
        });
        document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
          const key = el.getAttribute("data-i18n-placeholder");
          const value = t(key, lang);
          if (value) el.setAttribute("placeholder", value);
        });
        const toggle = document.getElementById("langToggle");
        if (toggle) toggle.textContent = lang === "fr" ? "AR" : "FR";
      }

      function getCart() {
        try {
          const raw = localStorage.getItem(CART_KEY);
          return raw ? JSON.parse(raw) : [];
        } catch (_) {
          return [];
        }
      }

      function saveCart(items) {
        localStorage.setItem(CART_KEY, JSON.stringify(items));
        updateBadge();
      }

      function updateBadge() {
        const count = getCart().reduce((sum, item) => sum + (item.qty || 0), 0);
        const desktop = document.getElementById("cartCount");
        const mobile = document.getElementById("cartCountMobile");
        if (desktop) desktop.textContent = String(count);
        if (mobile) mobile.textContent = String(count);
      }

      function addItem(item) {
        const items = getCart();
        const id = item.id || item.slug || item.name;
        const existing = items.find((it) => it.id === id);
        if (existing) {
          existing.qty += item.qty || 1;
        } else {
          items.push({
            id,
            name: item.name,
            slug: item.slug,
            price: Number(item.price) || 0,
            image: item.image || "/book.jpg",
            qty: item.qty || 1
          });
        }
        saveCart(items);
      }

      function removeItem(id) {
        saveCart(getCart().filter((item) => item.id !== id));
      }

      function updateQty(id, qty) {
        const items = getCart();
        const item = items.find((it) => it.id === id);
        if (!item) return;
        item.qty = Math.max(1, Number(qty) || 1);
        saveCart(items);
      }

      window.BoudaI18n = { getLang, t, applyLanguage };
      window.BoudaCart = { getCart, saveCart, addItem, removeItem, updateQty, updateBadge };
      document.addEventListener("DOMContentLoaded", function () {
        updateBadge();
        const lang = getLang();
        applyLanguage(lang);
        const toggle = document.getElementById("langToggle");
        if (toggle) {
          toggle.addEventListener("click", function () {
            const next = getLang() === "ar" ? "fr" : "ar";
            localStorage.setItem(LANG_KEY, next);
            applyLanguage(next);
          });
        }
      });
    })();

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
