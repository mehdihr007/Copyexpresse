<style>
  .about-hero { background: linear-gradient(180deg, #eef4ff 0%, var(--bg) 100%); padding: 60px 20px; text-align: center; }
  .about-content { max-width: 800px; margin: 0 auto; }
  .about-section { padding: 40px 0; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 30px; margin-top: 40px; }
  .stat-card { text-align: center; padding: 30px; background: var(--surface); border-radius: var(--radius); border: 1.5px solid var(--border); }
  .stat-card .number { font-size: 2.5rem; font-weight: 900; color: var(--primary); }
  .stat-card .label { color: var(--text-mid); font-weight: 600; }
  .values-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; margin-top: 30px; }
  .value-card { padding: 30px; background: var(--surface); border-radius: var(--radius); border: 1.5px solid var(--border); }
  .value-card h3 { font-size: 1.2rem; font-weight: 800; margin-bottom: 10px; }
</style>

